    "<text x='18' y='70'
        font-family='Segoe UI, Arial'
        font-size='16'
        font-weight='700'
        fill='" & SubTextColor & "'>" &
        FORMAT(KPI_LeftValue, "0.00") &
    "</text>" &

    "<text x='92' y='70'
        font-family='Segoe UI, Arial'
        font-size='16'
        font-weight='700'
        fill='" & SubTextColor & "'>" &
        FORMAT(KPI_RightValue, "0.00") &
    "</text>" &

    "<text x='18' y='94'
        font-family='Segoe UI, Arial'
        font-size='12'
        fill='" & LabelColor & "'>" &
        KPI_LeftLabel &
    "</text>" &

    "<text x='92' y='94'
        font-family='Segoe UI, Arial'
        font-size='12'
        fill='" & LabelColor & "'>" &
        KPI_RightLabel &
