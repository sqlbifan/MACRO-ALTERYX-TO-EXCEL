VAR KPI_Percent = 0.612
VAR KPI_LeftValue = 0.65
VAR KPI_RightValue = 0.40
VAR KPI_LeftLabel = "מטרה"
VAR KPI_RightLabel = "מדד"

VAR BgColor = "#D9D9D9"
VAR BorderColor = "#BFBFBF"
VAR MainTextColor = "#000000"
VAR SubTextColor = "#000000"
VAR LabelColor = "#6E6E6E"

RETURN
"data:image/svg+xml;utf8," &
"<svg xmlns='http://www.w3.org/2000/svg' width='180' height='104' viewBox='0 0 180 104'>" &

    "<rect x='0.5' y='0.5' width='179' height='103' fill='" & BgColor & "' stroke='" & BorderColor & "' stroke-width='1'/>" &

    "<text x='18' y='36'
