SCORE = 
DIVIDE([MADAD_YTD],[TARGET_YTD],0)

SCORE_LIMIT = 
VAR SPREAD_SCORE_SHILD = 
SWITCH(TRUE(),
SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {5} && [SCORE] >= 1, 1 ,
SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {6} && [SCORE] >= 1,1,0)
RETURN
SWITCH(TRUE(),
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.7,9.8} && [SCORE] >= 1 , 1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.7,9.8} && [SCORE] < 1 , -1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.91,9.9} && [SCORE] >= 1 , -1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.91,9.9} && [SCORE] < 1 , 1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.7} && [SCORE] >= 1 , 1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.7} && [SCORE] < 0.4/0.6 && SPREAD_SCORE_SHILD = 0 , -1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.7} && [SCORE] < 0.4/0.6 && SPREAD_SCORE_SHILD = 1 , 0,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.7} && [SCORE] >= 0.4/0.6 && [SCORE] < 1 , 0,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.92} && [SCORE] >= 1 , 1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.92} && [SCORE] < 12/16 , -1,
    SELECTEDVALUE('MADAD_SELECT'[SORT]) IN {9.92} && [SCORE] >= 12/16 && [SCORE] <1 , 0,
    [SCORE] > 1 , 1,  תקרה של מקסימום 100 
    [SCORE]
)
