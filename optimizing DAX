AVERAGEX(
SUMMARIZECOLUMNS('malmash_bankait_converter'[Zone_Desc_Update_FULL], 'malmash_bankait_converter'[BRANCH_DESC] ,"@MESHUKLAL",
[WEIGHT_SUMX])
, [@MESHUKLAL])

