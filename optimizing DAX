9.4,0.06,
9.5, 0.06, 
9.7, 0.03,
9.8, 0.02,
9.9,0.02,
9.91,0.02,
9.92,0.03
)

WEIGHT_SUMX = 
SUMX(
SUMMARIZECOLUMNS('malmash_bankait_converter'[Zone_Desc_Update_FULL], 'malmash_bankait_converter'[BRANCH_DESC],'MADAD_SELECT'[NAME], "@MESHUKLAL",
